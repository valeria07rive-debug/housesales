<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="real_estate.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1595"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="available_properties" custom_title="0" dock_id="3" table="4,20:mainavailable_properties"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="available_properties" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="21"/><column index="2" value="34"/><column index="3" value="60"/><column index="4" value="101"/><column index="5" value="41"/><column index="6" value="49"/><column index="7" value="82"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">CREATE TABLE properties (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL,
    address TEXT NOT NULL,
    property_type TEXT,
    price REAL CHECK(price &gt; 0),
    status TEXT CHECK(status IN ('available','sold','rented','reserved')),
    description TEXT
);

CREATE TABLE clients (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    full_name TEXT NOT NULL,
    phone TEXT,
    email TEXT
);

CREATE TABLE transactions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    property_id INTEGER,
    client_id INTEGER,
    transaction_type TEXT CHECK(transaction_type IN ('sale','rent')),
    amount REAL,
    transaction_date TEXT,
    FOREIGN KEY(property_id) REFERENCES properties(id),
    FOREIGN KEY(client_id) REFERENCES clients(id)
);

CREATE VIEW available_properties AS
SELECT * FROM properties WHERE status='available';</sql><current_tab id="0"/></tab_sql></sqlb_project>
